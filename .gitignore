# Local environment
.env
.env.*
!.env.example

# Local Kubernetes access material
.kube/
*.kubeconfig
kubeconfig

# Raw or decrypted secrets must not be committed
*.secret.yaml
*.secrets.yaml
*.decrypted.yaml
*.unsealed.yaml
*.dec.yaml
secrets/
decrypted-secrets/

# Editors and OS files
*~
*.swp
.DS_Store

# Chunk 7 / Sealed Secrets safety: never commit private key backups or plaintext secret material.
main.key
*.key
*.private.pem
sealed-secrets-master-key-*.yaml
plain-secret*.yaml
unsealed-secret*.yaml
*.unsealed.yaml
.scratch/
.secret-values/

